      <description>
      
        
        
          &lt;h3 id=&quot;동명-동물-수-찾기&quot;&gt;&lt;a href=&quot;#동명-동물-수-찾기&quot; class=&quot;headerlink&quot; title=&quot;동명 동물 수 찾기&quot;&gt;&lt;/a&gt;동명 동물 수 찾기&lt;/h3&gt;&lt;p&gt;&lt;img src=&quot;/image/sql_013.PNG&quot; alt=&quot;&quot;&gt;&lt;
        
      
